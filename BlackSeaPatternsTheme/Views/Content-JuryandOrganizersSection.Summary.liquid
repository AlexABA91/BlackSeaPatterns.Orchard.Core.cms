<section id="organizers" class="organizers-section section">
			<h2 class="jury-title">{{Model.ContentItem.Content.JuryandOrganizersSection.TittleOne.Text}}</h2>
			<div class="jury-photos swiper jury-swiper">
				<div class="jury-track" id="jurySwiperWrapper">
						{% for item in Model.ContentItem.Content.Jury.ContentItems %} 
							<div class="jury-track-item">
								<div class="jury-track-image-background" 
								style="background-image: url('{{Model.ContentItem.Content.JuryandOrganizersSection.BackgroundImg.Paths | asset_url }}')">
									<img src="{{item.SliderItem.Image.Paths | asset_url }}" 
									alt="{{item.SliderItem.Image.MediaTexts}}"/>
								</div>
								<h3>{{item.TitlePart.Title}}</h3>
							</div>
						{% endfor %}
				</div>
			</div>
			<p class="jury-disclaimer">{{Model.ContentItem.Content.TitlePart.Title}}</p>
			<h2 class="organizers-title">{{Model.ContentItem.Content.JuryandOrganizersSection.TitleTwo.Text}}</h2>
			<div class="organizers-photos swiper organizers-swiper">
				<div class="organizers-track" id="organizersSwiperWrapper">
						{% for item in Model.ContentItem.Content.Organizers.ContentItems %} 
						<div class="organizers-track-item">
							<div class="organizers-track-image-background" 
							style="background-image: url('{{Model.ContentItem.Content.JuryandOrganizersSection.BackgroundImg.Paths | asset_url }}')">
								<img src="{{item.SliderItem.Image.Paths | asset_url }}" 
								alt="{{item.SliderItem.Image.MediaTexts}}"/>
							</div>
							<h3>{{item.TitlePart.Title}}</h3>
						</div>
						{% endfor %}
				</div> 
			</div>

		</section>